# singbox-dashboard 环境变量
# 复制: cp .env.example .env

# ── 架构 (Docker manifest list 自动选择，无需手动指定) ──
# DOCKER_PLATFORM=  ← 留空，Docker 自动拉取匹配架构的镜像

# ── 网络模式 ─────────────────────────────────────────
# Linux/WSL2 建议 host，macOS 必须 bridge
NETWORK_MODE=bridge

# ── 数据目录 ─────────────────────────────────────────
DATA_DIR=./data

# ── 端口 (仅 bridge 模式) ────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=9092
SINGBOX_MIXED_PORT=2080
SINGBOX_CLASH_PORT=9090