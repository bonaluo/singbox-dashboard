# singbox-dashboard 环境变量示例
# 复制为 .env 后按需修改

# ── 数据存储目录 ──────────────────────────────
# Linux/WSL2: /mnt/g/docker/singbox-dashboard
# macOS:      ./data
DATA_DIR=./data

# ── 镜像配置 ──────────────────────────────────
# 正式环境（docker-compose.yml）使用云端镜像
# BACKEND_IMAGE=bonaluo/singbox-dashboard-backend
# FRONTEND_IMAGE=bonaluo/singbox-dashboard-frontend
# TAG=latest

# 开发环境（docker-compose.dev.yml）使用本地构建
# BACKEND_IMAGE=singbox-dashboard-backend
# FRONTEND_IMAGE=singbox-dashboard-frontend
# TAG=local

# ── 端口配置 ──────────────────────────────────
# FRONTEND_PORT=9000
# BACKEND_PORT=9092
# SINGBOX_MIXED_PORT=2080
# SINGBOX_CLASH_PORT=9090

# ── 构建参数（仅开发环境）─────────────────────
# GO_IMAGE=docker.m.daocloud.io/library/golang:1.25-alpine
# NODE_IMAGE=docker.m.daocloud.io/library/node:22.sz.alpine
# NPM_REGISTRY=https://registry.npmmirror.com
# GIT_COMMIT=unknown
# VERSION=unknown
