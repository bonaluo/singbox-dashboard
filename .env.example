# singbox-dashboard 开发环境变量示例
# 复制为 .env.dev 后按需修改
#
# TAG 由 build.sh 通过当前日期自动生成（格式 yy.mm.dd.hh.mm），无需在此配置

# ── Compose 项目名（dev 独立项目避免干扰正式环境）─
COMPOSE_PROJECT_NAME=singbox-dashboard-dev

# ── 数据存储目录 ──────────────────────────────
DATA_DIR=./data

# ── 容器名称（dev 环境以 -dev 结尾）───────────
BACKEND_CONTAINER=singbox-backend-dev
FRONTEND_CONTAINER=singbox-frontend-dev

# ── 镜像配置 ──────────────────────────────────
BACKEND_IMAGE=singbox-dashboard-backend
FRONTEND_IMAGE=singbox-dashboard-frontend

# ── 构建参数 ──────────────────────────────────
# 本地用镜像加速，CI 环境用官方源
# GO_IMAGE=docker.m.daocloud.io/library/golang:1.25-alpine
# NODE_IMAGE=docker.m.daocloud.io/library/node:22-alpine
# NPM_REGISTRY=https://registry.npmmirror.com
# NEXT_PUBLIC_API=http://localhost:9093

# ── 端口配置（正式环境 +1 避免冲突）───────────
# FRONTEND_PORT=9001
# BACKEND_PORT=9093
# SINGBOX_MIXED_PORT=2081
# SINGBOX_CLASH_PORT=9091
